{
  "info": {
    "name": "CRM Médico API",
    "description": "Coleção para a API NestJS do CRM. Com `docker compose`, a API fica em **http://localhost:3001** (ajuste `baseUrl` se usar `CRM_API_PORT`). Após `migration:run`, use **Login (admin)** com `admin@clinica-legacy.local` / `Senha123!`. Variáveis `patientId` e `appointmentId` vêm do seed inicial.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "accessToken", "value": "" },
    { "key": "tenantId", "value": "11111111-1111-4111-8111-111111111111" },
    { "key": "patientId", "value": "dddddddd-dddd-4ddd-8ddd-dddddddddddd" },
    { "key": "appointmentId", "value": "eeeeeeee-eeee-4eee-8eee-eeeeeeeeeeee" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  pm.collectionVariables.set('tenantId', j.user.tenantId);",
                  "  pm.collectionVariables.set('userId', j.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinica-legacy.local\",\n  \"password\": \"Senha123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Grava `accessToken`, `tenantId` e `userId` nas variáveis da coleção."
          }
        },
        {
          "name": "Login (atendente seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  pm.collectionVariables.set('tenantId', j.user.tenantId);",
                  "  pm.collectionVariables.set('userId', j.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"atendente@clinica-legacy.local\",\n  \"password\": \"Senha123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (viewer seed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  pm.collectionVariables.set('tenantId', j.user.tenantId);",
                  "  pm.collectionVariables.set('userId', j.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@clinica-legacy.local\",\n  \"password\": \"Senha123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Create tenant",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Clínica Exemplo\",\n  \"slug\": \"clinica-exemplo-{{$timestamp}}\",\n  \"email\": \"contato@clinica.com\"\n}"
            },
            "url": "{{baseUrl}}/tenants",
            "description": "Público. Ajuste `slug` se já existir (use sufixo único)."
          }
        },
        {
          "name": "Get tenant",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tenants/{{tenantId}}",
            "description": "Requer ADMIN do mesmo tenant."
          }
        },
        {
          "name": "Update tenant",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Clínica Legacy (atualizado)\",\n  \"phone\": \"1133334444\"\n}"
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users?page=1&limit=20"
          }
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Novo Colaborador\",\n  \"email\": \"colaborador.novo@clinica-legacy.local\",\n  \"password\": \"Senha123!\",\n  \"role\": \"ATTENDANT\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nome atualizado\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Change role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"MANAGER\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/role",
            "description": "Só ADMIN. Cuidado ao alterar seu próprio papel."
          }
        },
        {
          "name": "Deactivate user",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Só ADMIN."
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "List patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients?page=1&limit=20&search=Maria"
          }
        },
        {
          "name": "Get patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}"
          }
        },
        {
          "name": "Create patient",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Teste\",\n  \"cpf\": \"11144477735\",\n  \"phone\": \"11988887777\",\n  \"gender\": \"MALE\",\n  \"email\": \"joao.teste@email.com\"\n}"
            },
            "url": "{{baseUrl}}/patients"
          }
        },
        {
          "name": "Update patient",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Observação de teste via Postman\"\n}"
            },
            "url": "{{baseUrl}}/patients/{{patientId}}"
          }
        },
        {
          "name": "Activate patient",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}/activate"
          }
        },
        {
          "name": "Deactivate patient",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}/deactivate"
          }
        },
        {
          "name": "Delete patient",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/patients/{{patientId}}",
            "description": "MANAGER+"
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "List appointments",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/appointments?page=1&limit=20&status=AGUARDANDO"
          }
        },
        {
          "name": "Get appointment",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Create appointment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"type\": \"CONSULTATION\",\n  \"priority\": \"NORMAL\",\n  \"description\": \"Novo atendimento criado pelo Postman\",\n  \"scheduledAt\": \"2026-04-01T14:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/appointments"
          }
        },
        {
          "name": "Advance status (→ EM_ATENDIMENTO)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_ATENDIMENTO\"\n}"
            },
            "url": "{{baseUrl}}/appointments/{{appointmentId}}/status"
          }
        },
        {
          "name": "Advance status (→ FINALIZADO)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"FINALIZADO\"\n}"
            },
            "url": "{{baseUrl}}/appointments/{{appointmentId}}/status"
          }
        },
        {
          "name": "Cancel appointment",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Paciente desmarcou\"\n}"
            },
            "url": "{{baseUrl}}/appointments/{{appointmentId}}/cancel"
          }
        },
        {
          "name": "Add note",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Nota adicionada via Postman\"\n}"
            },
            "url": "{{baseUrl}}/appointments/{{appointmentId}}/notes"
          }
        },
        {
          "name": "Update appointment",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Descrição atualizada (somente MANAGER+)\",\n  \"priority\": \"HIGH\"\n}"
            },
            "url": "{{baseUrl}}/appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Delete appointment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/appointments/{{appointmentId}}",
            "description": "MANAGER+"
          }
        }
      ]
    }
  ]
}
